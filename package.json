{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "start": "concurrently --kill-others-on-fail \"php artisan serve\" \"vite\"",
        "build:mobile": "vite build --config vite.config.mobile.js --mode mobile",
        "cap:sync": "npm run build:mobile && cap sync",
        "cap:android": "npm run cap:sync && cap open android",
        "cap:ios": "npm run cap:sync && cap open ios"
    },
    "dependencies": {
        "@capacitor-community/barcode-scanner": "^4.0.1",
        "@capacitor/android": "^5.7.8",
        "@capacitor/core": "^5.7.8",
        "@capacitor/ios": "^5.7.8",
        "@fullcalendar/core": "^5.7.2",
        "@fullcalendar/daygrid": "^5.7.2",
        "@fullcalendar/interaction": "^5.7.2",
        "@fullcalendar/timegrid": "^5.7.2",
        "@fullcalendar/vue3": "^5.7.2",
        "axios": "^1.15.2",
        "chart.js": "3.3.2",
        "html5-qrcode": "^2.3.8",
        "primeflex": "^3.3.0",
        "primeicons": "^6.0.1",
        "primevue": "3.49.1",
        "prismjs": "^1.9.0",
        "qrcode": "^1.5.4",
        "quill": "^1.3.7",
        "vue": "^3.2.45",
        "vue-router": "^4.1.6"
    },
    "devDependencies": {
        "@capacitor/cli": "^5.7.8",
        "@vitejs/plugin-vue": "^6.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "sass": "^1.54.4",
        "vite": "^8.0.0",
        "vite-plugin-static-copy": "^4.1.0"
    }
}
